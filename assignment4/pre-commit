#!/bin/bash

# Get the name of the current branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Only run tests if we are committing to the 'main' branch
if [ "$BRANCH" = "main" ]; then
    echo "Committing to main branch. Running tests first..."

    # Activate the virtual environment (Windows Git Bash format)
    source env/Scripts/activate

    # Run the tests
    pytest test.py

    # Capture the exit code of pytest (0 means pass, 1 means fail)
    RESULT=$?

    # If pytest failed, abort the commit
    if [ $RESULT -ne 0 ]; then
        echo "Tests failed! Commit aborted. Please fix the errors and try again."
        exit 1
    fi

    echo "All tests passed! Proceeding with the commit."
fi

# Exit cleanly
exit 0